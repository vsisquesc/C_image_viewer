{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(gdb) Launch main",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/raylib_image_viewer.out",
            "args": [ "gray", "images/fourbyfour_p3.ppm"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                { "text": "set output-radix 16" }
            ]
        }
    ]
}
